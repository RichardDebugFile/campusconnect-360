# =============================================================================
# CampusConnect 360 - Variables de entorno de ejemplo
# -----------------------------------------------------------------------------
# El docker-compose.yml ya define valores por defecto para desarrollo, así que
# NO necesitas un .env para levantar el proyecto. Este archivo documenta las
# variables disponibles por si quieres ejecutar un servicio de forma aislada
# (fuera de Docker) o cambiar credenciales/secretos.
#
# Uso (opcional):  cp .env.example .env
# =============================================================================

# --- PostgreSQL (clúster compartido, una base por servicio) ------------------
POSTGRES_USER=campus
POSTGRES_PASSWORD=campus

# Cadenas de conexión por servicio (host "postgres" = nombre del contenedor)
ACADEMIC_DATABASE_URL=postgres://campus:campus@postgres:5432/academicdb
PAYMENTS_DATABASE_URL=postgres://campus:campus@postgres:5432/paymentsdb
ATTENDANCE_DATABASE_URL=postgres://campus:campus@postgres:5432/attendancedb
NOTIFICATIONS_DATABASE_URL=postgres://campus:campus@postgres:5432/notificationsdb
ANALYTICS_DATABASE_URL=postgres://campus:campus@postgres:5432/analyticsdb

# --- RabbitMQ ----------------------------------------------------------------
AMQP_URL=amqp://guest:guest@rabbitmq:5672

# --- Gateway / Seguridad -----------------------------------------------------
# Secreto para firmar los JWT. CÁMBIALO en cualquier entorno que no sea local.
JWT_SECRET=campusconnect-dev-secret

# URLs internas de los servicios (las usa el gateway para enrutar y health-check)
ACADEMIC_URL=http://academic:3001
PAYMENTS_URL=http://payments:3002
ATTENDANCE_URL=http://attendance:3003
NOTIFICATIONS_URL=http://notifications:3004
ANALYTICS_URL=http://analytics:3005

# --- Notificaciones (escenario de falla controlada) --------------------------
# Si se pone en "true", el servicio simula caída del canal de entrega para
# demostrar reintentos -> Dead Letter Queue. También se puede activar en
# caliente desde el dashboard (panel de resiliencia).
FAIL_MODE=false
